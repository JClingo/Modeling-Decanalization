@article{tentori_conjunction_2012,
  title        = {On the conjunction fallacy and the meaning of and, yet again: A reply to},
  volume       = {122},
  issn         = {00100277},
  url          = {https://linkinghub.elsevier.com/retrieve/pii/S0010027711002320},
  doi          = {10.1016/j.cognition.2011.09.002},
  shorttitle   = {On the conjunction fallacy and the meaning of and, yet again},
  abstract     = {In this paper we question the theoretical tenability of Hertwig, Benz, and Krauss’s (2008) ({HBK}) argument that responses commonly taken as manifestations of the conjunction fallacy should be instead considered as reﬂecting ‘‘reasonable pragmatic and semantic inferences’’ because the meaning of and does not always coincide with that of the logical operator {\textasciicircum}. We also question the relevance of the experimental evidence that {HBK} provide in support of their argument as well as their account of the pertinent literature. Finally, we report two novel experiments in which we employed {HBK}’s procedure to control for the interpretation of and. The results obtained overtly contradict {HBK}’s data and claims. We conclude with a discussion on the alleged feebleness of the conjunction fallacy, and suggest directions that future research on this topic might pursue.},
  pages        = {123--134},
  number       = {2},
  journaltitle = {Cognition},
  shortjournal = {Cognition},
  author       = {Tentori, Katya and Crupi, Vincenzo},
  urldate      = {2021-05-28},
  date         = {2012-02},
  langid       = {english},
  keywords     = {Bias, Conjunction, Fallacy}
}

