@article{hart_development_2022,
  title        = {The development of creative search strategies},
  volume       = {225},
  issn         = {0010-0277},
  url          = {https://www.sciencedirect.com/science/article/pii/S0010027722000907},
  doi          = {10.1016/j.cognition.2022.105102},
  abstract     = {How does creativity develop? Creativity is a multi-faceted behavior and thus it is difficult to find measures for creativity that are both precise and comparable across development. Here, we examine the development of creativity using a “creative foraging” task. The task measures different facets of creativity which we compare between 4- to 8-year-old children and adults. We find that compared to adults, children spend a higher percentage of their search exploring, and their exploitation phases are less efficient. Moreover, children orient their search to a different and smaller region of the search space, but within that space they produce more unique creative products. Lastly, as children grow up, their creative products become more adult-like and their uniqueness decreases. Together, these results suggest that creative search changes across development, in the search strategy employed, in how the space of possibilities is navigated, and in what ideas are ultimately chosen.},
  pages        = {105102},
  journaltitle = {Cognition},
  shortjournal = {Cognition},
  author       = {Hart, Yuval and Kosoy, Eliza and Liquin, Emily G. and Leonard, Julia A. and Mackey, Allyson P. and Gopnik, Alison},
  urldate      = {2022-10-18},
  date         = {2022-08-01},
  langid       = {english},
  keywords     = {Children, Creative foraging game, Creativity, Development, Exploration-exploitation, children, creativity, exploit, explore, foraging, search}
}

