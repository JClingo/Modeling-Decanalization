@article{garcia-romeu_current_2018,
  title        = {Current perspectives on psychedelic therapy: use of serotonergic hallucinogens in clinical interventions},
  volume       = {30},
  issn         = {0954-0261},
  url          = {https://doi.org/10.1080/09540261.2018.1486289},
  doi          = {10.1080/09540261.2018.1486289},
  shorttitle   = {Current perspectives on psychedelic therapy},
  abstract     = {Humans have used serotonergic hallucinogens (i.e. psychedelics) for spiritual, ceremonial, and recreational purposes for thousands of years, but their administration as part of a structured therapeutic intervention is still a relatively novel practice within Western medical and psychological frameworks. In the mid-20th century, considerable advances were made in developing therapeutic approaches integrating administration of low (psycholytic) and high (psychedelic) doses of serotonergic hallucinogens for treatment of a variety of conditions, often incorporating psychoanalytic concepts prevalent at that time. This work contributed seminal insights regarding how these substances may be employed with efficacy and safety in targeted therapeutic interventions, including the importance of optimizing set (frame of mind) and setting (therapeutic environment). More recently, clinical and pharmacological research has revisited the effects and therapeutic potential of psychedelics utilizing a variety of approaches. The current article provides an overview of past and present models of psychedelic therapy, and discusses important considerations for future interventions incorporating the use of psychedelics in research and clinical practice.},
  pages        = {291--316},
  number       = {4},
  journaltitle = {International Review of Psychiatry},
  author       = {Garcia-Romeu, Albert and Richards, William A.},
  urldate      = {2023-11-06},
  date         = {2018-07-04},
  pmid         = {30422079},
  note         = {Publisher: Taylor \& Francis
                  \_eprint: https://doi.org/10.1080/09540261.2018.1486289},
  keywords     = {{LSD}, Psychedelic therapy, hallucinogens, integration, psilocybin}
}

@article{eisner_set_1997,
  title        = {Set, Setting, and Matrix},
  volume       = {29},
  issn         = {0279-1072},
  url          = {https://doi.org/10.1080/02791072.1997.10400190},
  doi          = {10.1080/02791072.1997.10400190},
  abstract     = {The future use of psychedelics as an aid to therapeutic change is bound to come. The best source of information on how to use these extraordinary drugs is clearly a detailed description of the successes (and failures) of those researchers who have used these compounds to bring curative, creative and growth-potentiating experiences to their patients. A study of their work is recommended in order to identify those elements that lead to successful sessions. Two known essential elements are “set,” which involves the personality and expectations of the patient, and “setting,” which has to do with the environment of the session. A third element of importance is that of “matrix,” which includes consideration of the environment (1) from which an individual comes, (2) in which the individual lives during the time of the sessions, and (3) to which the individual returns after successful therapy—the everyday living space; these three elements are discussed.},
  pages        = {213--216},
  number       = {2},
  journaltitle = {Journal of Psychoactive Drugs},
  author       = {Eisner, Betty},
  urldate      = {2023-11-06},
  date         = {1997-06-01},
  pmid         = {9250949},
  note         = {Publisher: Taylor \& Francis
                  \_eprint: https://doi.org/10.1080/02791072.1997.10400190},
  keywords     = {conciousness-changing, integration, mind-manifesting, psychedelic, set, setting, therapy}
}

