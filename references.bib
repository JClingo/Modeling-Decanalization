  keywords     = {Chronic depression, Cognitive change in depression, Depression, Depressive Disorder, Major, Dynamic systems theory, Emotional processing, Humans, Models, Psychological, Psychological Theory, Psychotherapeutic Processes}
}

@article{carhart-harris_psilocybin_2018,
  title        = {Psilocybin with psychological support for treatment-resistant depression: six-month follow-up},
  volume       = {235},
  issn         = {1432-2072},
  doi          = {10.1007/s00213-017-4771-x},
  shorttitle   = {Psilocybin with psychological support for treatment-resistant depression},
  abstract     = {{RATIONALE}: Recent clinical trials are reporting marked improvements in mental health outcomes with psychedelic drug-assisted psychotherapy.
                  {OBJECTIVES}: Here, we report on safety and efficacy outcomes for up to 6 months in an open-label trial of psilocybin for treatment-resistant depression.
                  {METHODS}: Twenty patients (six females) with (mostly) severe, unipolar, treatment-resistant major depression received two oral doses of psilocybin (10 and 25 mg, 7 days apart) in a supportive setting. Depressive symptoms were assessed from 1 week to 6 months post-treatment, with the self-rated {QIDS}-{SR}16 as the primary outcome measure.
                  {RESULTS}: Treatment was generally well tolerated. Relative to baseline, marked reductions in depressive symptoms were observed for the first 5 weeks post-treatment (Cohen's d = 2.2 at week 1 and 2.3 at week 5, both p {\textless} 0.001); nine and four patients met the criteria for response and remission at week 5. Results remained positive at 3 and 6 months (Cohen's d = 1.5 and 1.4, respectively, both p {\textless} 0.001). No patients sought conventional antidepressant treatment within 5 weeks of psilocybin. Reductions in depressive symptoms at 5 weeks were predicted by the quality of the acute psychedelic experience.
                  {CONCLUSIONS}: Although limited conclusions can be drawn about treatment efficacy from open-label trials, tolerability was good, effect sizes large and symptom improvements appeared rapidly after just two psilocybin treatment sessions and remained significant 6 months post-treatment in a treatment-resistant cohort. Psilocybin represents a promising paradigm for unresponsive depression that warrants further research in double-blind randomised control trials.},
  pages        = {399--408},
  number       = {2},
  journaltitle = {Psychopharmacology},
  shortjournal = {Psychopharmacology (Berl)},
  author       = {Carhart-Harris, R. L. and Bolstridge, M. and Day, C. M. J. and Rucker, J. and Watts, R. and Erritzoe, D. E. and Kaelen, M. and Giribaldi, B. and Bloomfield, M. and Pilling, S. and Rickard, J. A. and Forbes, B. and Feilding, A. and Taylor, D. and Curran, H. V. and Nutt, D. J.},
  date         = {2018-02},
  pmid         = {29119217},
  pmcid        = {PMC5813086},
  keywords     = {5-{HT}2AR, Adult, Antidepressive Agents, Combined Modality Therapy, Depression, Depressive Disorder, Treatment-Resistant, Double-Blind Method, Feasibility Studies, Female, Follow-Up Studies, Hallucinogen, Hallucinogens, Humans, Male, Middle Aged, Mood, Psilocybin, Psychedelic, Psychosocial Support Systems, Psychotherapy, Serotonin, Time Factors, Treatment Outcome, Treatment-resistant depression, depression, psilocybin, psychotherapy}
}

@article{hipolito_pattern_2023,
  title        = {Pattern breaking: a complex systems approach to psychedelic medicine},
  volume       = {2023},
  issn         = {2057-2107},
  url          = {https://doi.org/10.1093/nc/niad017},
  doi          = {10.1093/nc/niad017},
  shorttitle   = {Pattern breaking},
  abstract     = {Recent research has demonstrated the potential of psychedelic therapy for mental health care. However, the psychological experience underlying its therapeutic effects remains poorly understood. This paper proposes a framework that suggests psychedelics act as destabilizers, both psychologically and neurophysiologically. Drawing on the ‘entropic brain’ hypothesis and the ‘{RElaxed} Beliefs Under {pSychedelics}’ model, this paper focuses on the richness of psychological experience. Through a complex systems theory perspective, we suggest that psychedelics destabilize fixed points or attractors, breaking reinforced patterns of thinking and behaving. Our approach explains how psychedelic-induced increases in brain entropy destabilize neurophysiological set points and lead to new conceptualizations of psychedelic psychotherapy. These insights have important implications for risk mitigation and treatment optimization in psychedelic medicine, both during the peak psychedelic experience and during the subacute period of potential recovery.},
  pages        = {niad017},
  number       = {1},
  journaltitle = {Neuroscience of Consciousness},
  shortjournal = {Neuroscience of Consciousness},
  author       = {Hipólito, Inês and Mago, Jonas and Rosas, Fernando E and Carhart-Harris, Robin},
  urldate      = {2023-09-21},
  date         = {2023-01-01},
  keywords     = {{REBUS}, complexity, entropy, pattern, psychedelics}
}

